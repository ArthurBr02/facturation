// Prisma schema — Facturation (AB Corp).
// Phase 0: single-user auth, clients, app settings, templates, number counters, upload queue.
// Phase 1: invoices (factures), credit notes (avoirs), encaissements.
// Sprint 1.5: product/service catalog (produits).
// Phase 2: devis, avenants; facture enriched with devisId + execution date range.
// Phase 3: maintenance contracts, interventions, monthly invoicing.
// Phase 3.5: client enriched (tjmNegocie, notesInternes, contactPrincipal); dashboard actions; client 360°.
// Phase 4: RevenuMalt for Malt platform revenue; enhanced seuils + URSSAF assistant; livre des recettes.
// Phase 5/6: Template.customHtml for custom PDF rendering.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Single application user (mono-utilisateur). Seeded from ADMIN_* env vars.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum ClientType {
  pro
  particulier
}

/// A customer (B2B "pro" or B2C "particulier").
model Client {
  id                 Int        @id @default(autoincrement())
  type               ClientType @default(pro)
  pays               String     @default("France")
  nom                String
  denomination       String?
  formeJuridique     String?    @map("forme_juridique")
  email              String?
  telephone          String?
  adresse1           String?
  adresse2           String?
  codePostal         String?    @map("code_postal")
  ville              String?
  siren              String?
  tvaIntra           String?    @map("tva_intra")
  conditionsPaiement Int?       @map("conditions_paiement")
  // Phase 3.5 — enriched client fields
  contactPrincipal   String?    @map("contact_principal")
  tjmNegocie         Decimal?   @map("tjm_negocie") @db.Decimal(12, 2)
  notesInternes      String?    @map("notes_internes") @db.Text
  actif              Boolean    @default(true)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  factures Facture[]
  devis    Devis[]
  contrats ContratMaintenance[]

  @@index([nom])
  @@map("clients")
}

/// Key/value application settings. Drives placeholders + the onboarding wizard.
/// The special key `onboarding_complete` = 'true'/'false' gates the wizard.
model AppSetting {
  cle            String   @id
  valeur         String?
  groupe         String
  label          String?
  requis         Boolean  @default(false)
  onboardingStep Int?     @map("onboarding_step")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([groupe])
  @@map("app_settings")
}

enum TemplateType {
  devis
  avenant
  facture
  contrat
}

/// A reusable document skeleton with {{placeholders}}.
/// customHtml: optional user-uploaded HTML/CSS override (Phase 6).
model Template {
  id          Int          @id @default(autoincrement())
  nom         String
  type        TemplateType
  description String?
  estDefaut   Boolean      @default(false) @map("est_defaut")
  version     Int          @default(1)
  customHtml  String?      @map("custom_html") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  lignes  TemplateLine[]
  clauses TemplateClause[]

  @@index([type])
  @@map("templates")
}

/// A templated line item. Fields may contain {{placeholders}}.
model TemplateLine {
  id                   Int     @id @default(autoincrement())
  templateId           Int     @map("template_id")
  designationTemplate  String  @map("designation_template")
  quantiteTemplate     Decimal @default(0) @map("quantite_template") @db.Decimal(10, 2)
  prixUnitaireTemplate Decimal @default(0) @map("prix_unitaire_template") @db.Decimal(12, 2)
  ordre                Int     @default(0)

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_lines")
}

/// A templated free-text clause (objet, description, hébergement…).
model TemplateClause {
  id              Int    @id @default(autoincrement())
  templateId      Int    @map("template_id")
  cle             String
  contenuTemplate String @map("contenu_template") @db.Text

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_clauses")
}

enum NumberSeries {
  DEV
  AVE
  FAC
  AVO
  MNT
}

/// Sequential number counter, one row per (year, series). Incremented inside
/// the same transaction as the document finalisation to guarantee no gaps.
model NumberCounter {
  annee         Int
  serie         NumberSeries
  dernierNumero Int          @default(0) @map("dernier_numero")

  @@id([annee, serie])
  @@map("number_counters")
}

enum UploadStatus {
  pending
  failed
  done
}

/// Resilient queue for Google Drive uploads. Every finalised PDF is enqueued;
/// a background worker retries failed uploads and triggers e-mail alerts.
model UploadQueue {
  id           Int          @id @default(autoincrement())
  filePath     String       @map("file_path")
  drivePath    String       @map("drive_path")
  status       UploadStatus @default(pending)
  attempts     Int          @default(0)
  lastAttempt  DateTime?    @map("last_attempt")
  errorMessage String?      @map("error_message")
  documentType String?      @map("document_type")
  documentId   Int?         @map("document_id")
  driveFileId  String?      @map("drive_file_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([status])
  @@map("upload_queue")
}

// ─── Sprint 1.5 — Product / service catalog ──────────────────────────────────

enum UniteService {
  jour
  heure
  forfait
  unite
}

/// Reusable product/service for quick-fill of document lines.
model Produit {
  id          Int          @id @default(autoincrement())
  reference   String?      @unique
  designation String
  description String?      @db.Text
  categorie   String?
  prixDefaut  Decimal      @default(0) @map("prix_defaut") @db.Decimal(12, 2)
  unite       UniteService @default(unite)
  actif       Boolean      @default(true)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([actif])
  @@index([categorie])
  @@map("produits")
}

// ─── Phase 2 — Devis & Avenants ──────────────────────────────────────────────

enum DevisStatut {
  brouillon
  finalise
  envoye
  accepte
  refuse
  expire
  annule
}

/// A quote/proposal. Once accepted, serves as the contractual anchor for
/// factures and avenants. Draft is mutable; finalised is locked + numbered.
model Devis {
  id                Int         @id @default(autoincrement())
  clientId          Int?        @map("client_id")
  numero            String?     @unique
  statut            DevisStatut @default(brouillon)
  titre             String?
  description       String?     @db.Text
  dateEmission      DateTime    @map("date_emission") @db.Date
  validiteJours     Int         @default(30) @map("validite_jours")
  totalHt           Decimal     @default(0) @map("total_ht") @db.Decimal(12, 2)
  acomptePct        Decimal?    @map("acompte_pct") @db.Decimal(5, 2)
  cyclesInclus      Int         @default(3) @map("cycles_inclus")
  cyclesUtilises    Int         @default(0) @map("cycles_utilises")
  clauseRevision    String?     @map("clause_revision") @db.Text
  clauseHebergement String?     @map("clause_hebergement") @db.Text
  verrouillee       Boolean     @default(false)
  dateEnvoi         DateTime?   @map("date_envoi")
  signedPdfPath     String?     @map("signed_pdf_path")
  snapshot          Json?
  pdfPath           String?     @map("pdf_path")
  finaliseeAt       DateTime?   @map("finalisee_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  client   Client?      @relation(fields: [clientId], references: [id])
  lignes   LigneDevis[]
  factures Facture[]
  avenants Avenant[]

  @@index([statut])
  @@index([clientId])
  @@map("devis")
}

model LigneDevis {
  id           Int     @id @default(autoincrement())
  devisId      Int     @map("devis_id")
  designation  String  @db.Text
  quantite     Decimal @default(1) @db.Decimal(10, 2)
  prixUnitaire Decimal @default(0) @map("prix_unitaire") @db.Decimal(12, 2)
  ordre        Int     @default(0)

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
  @@map("devis_lines")
}

enum AvenantStatut {
  brouillon
  finalise
  envoye
  accepte
  refuse
  annule
}

/// An amendment to a finalised/accepted devis. Locked once finalised.
model Avenant {
  id            Int           @id @default(autoincrement())
  devisId       Int           @map("devis_id")
  numero        String?       @unique
  statut        AvenantStatut @default(brouillon)
  objet         String?       @db.Text
  description   String?       @db.Text
  delaiAdd      Int?          @map("delai_add")
  totalHt       Decimal       @default(0) @map("total_ht") @db.Decimal(12, 2)
  verrouillee   Boolean       @default(false)
  dateEmission  DateTime      @map("date_emission") @db.Date
  dateEnvoi     DateTime?     @map("date_envoi")
  signedPdfPath String?       @map("signed_pdf_path")
  snapshot      Json?
  pdfPath       String?       @map("pdf_path")
  finaliseeAt   DateTime?     @map("finalisee_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  devis  Devis        @relation(fields: [devisId], references: [id])
  lignes LigneAvenant[]

  @@index([statut])
  @@index([devisId])
  @@map("avenants")
}

model LigneAvenant {
  id           Int     @id @default(autoincrement())
  avenantId    Int     @map("avenant_id")
  designation  String  @db.Text
  quantite     Decimal @default(1) @db.Decimal(10, 2)
  prixUnitaire Decimal @default(0) @map("prix_unitaire") @db.Decimal(12, 2)
  ordre        Int     @default(0)

  avenant Avenant @relation(fields: [avenantId], references: [id], onDelete: Cascade)

  @@index([avenantId])
  @@map("avenant_lines")
}

// ─── Phase 1 — Factures & encaissements ──────────────────────────────────────

enum FactureType {
  standard
  acompte
  solde
  avoir
}

enum FactureStatut {
  brouillon
  finalisee
  payee
  partielle
}

enum MoyenPaiement {
  virement
  malt
  especes
  cheque
  autre
}

/// An invoice or credit note (avoir). HT = TTC (franchise en base de TVA).
model Facture {
  id     Int           @id @default(autoincrement())
  numero String?       @unique
  type   FactureType   @default(standard)
  statut FactureStatut @default(brouillon)

  clientId         Int? @map("client_id")
  devisId          Int? @map("devis_id")
  contratId        Int? @map("contrat_id")
  factureOrigineId Int? @map("facture_origine_id")

  dateEmission        DateTime  @map("date_emission") @db.Date
  dateExecutionDebut  DateTime? @map("date_execution_debut") @db.Date
  dateExecutionFin    DateTime? @map("date_execution_fin") @db.Date
  dateEcheance        DateTime? @map("date_echeance") @db.Date
  bonCommande         String?   @map("bon_commande")
  conditionsReglement String?   @map("conditions_reglement")
  objet               String?
  notes               String?   @db.Text

  totalHt     Decimal @default(0) @map("total_ht") @db.Decimal(12, 2)
  verrouillee Boolean @default(false)

  snapshot    Json?
  pdfPath       String?   @map("pdf_path")
  signedPdfPath String?   @map("signed_pdf_path")
  finaliseeAt DateTime? @map("finalisee_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client             Client?             @relation(fields: [clientId], references: [id])
  devis              Devis?              @relation(fields: [devisId], references: [id])
  contrat            ContratMaintenance? @relation(fields: [contratId], references: [id])
  factureOrigine     Facture?            @relation("FactureAvoirs", fields: [factureOrigineId], references: [id])
  avoirs             Facture[]           @relation("FactureAvoirs")
  lignes             LigneFacture[]
  encaissements      Encaissement[]
  periodeMaintenance PeriodeMaintenance?

  @@index([statut])
  @@index([clientId])
  @@map("factures")
}

model LigneFacture {
  id           Int     @id @default(autoincrement())
  factureId    Int     @map("facture_id")
  designation  String  @db.Text
  quantite     Decimal @default(1) @db.Decimal(10, 2)
  prixUnitaire Decimal @default(0) @map("prix_unitaire") @db.Decimal(12, 2)
  ordre        Int     @default(0)

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
  @@map("facture_lines")
}

/// A payment received against an invoice (comptabilité de trésorerie).
model Encaissement {
  id               Int           @id @default(autoincrement())
  factureId        Int           @map("facture_id")
  dateEncaissement DateTime      @map("date_encaissement") @db.Date
  montant          Decimal       @db.Decimal(12, 2)
  moyen            MoyenPaiement @default(virement)
  reference        String?
  createdAt        DateTime      @default(now()) @map("created_at")

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
  @@index([dateEncaissement])
  @@map("encaissements")
}

// ─── Phase 3 — Maintenance contracts ─────────────────────────────────────────

enum ContratStatut {
  actif
  suspendu
  resilie
}

/// A recurring maintenance contract attached to a client.
model ContratMaintenance {
  id               Int           @id @default(autoincrement())
  clientId         Int           @map("client_id")
  numero           String        @unique
  statut           ContratStatut @default(actif)
  titre            String?
  description      String?       @db.Text
  dateDebut        DateTime      @map("date_debut") @db.Date
  dureeMois        Int?          @map("duree_mois")
  reconduction     Boolean       @default(true)
  preavisJours     Int           @default(30) @map("preavis_jours")
  montantMensuel   Decimal       @map("montant_mensuel") @db.Decimal(12, 2)
  heuresIncluses   Decimal       @default(0) @map("heures_incluses") @db.Decimal(10, 2)
  reportHeures     Boolean       @default(false) @map("report_heures")
  thmDepassement   Decimal       @default(0) @map("thm_depassement") @db.Decimal(12, 2)
  perimetreCouvert String?       @map("perimetre_couvert") @db.Text
  exclusions       String?       @db.Text
  snapshot         Json?
  pdfPath          String?       @map("pdf_path")
  signedPdfPath    String?       @map("signed_pdf_path")
  dateResiliation  DateTime?     @map("date_resiliation") @db.Date
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  client        Client               @relation(fields: [clientId], references: [id])
  interventions Intervention[]
  periodes      PeriodeMaintenance[]
  factures      Facture[]

  @@index([statut])
  @@index([clientId])
  @@map("contrats_maintenance")
}

model Intervention {
  id          Int      @id @default(autoincrement())
  contratId   Int      @map("contrat_id")
  date        DateTime @db.Date
  dureeH      Decimal  @map("duree_h") @db.Decimal(10, 2)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  contrat ContratMaintenance @relation(fields: [contratId], references: [id], onDelete: Cascade)

  @@index([contratId])
  @@index([date])
  @@map("interventions")
}

/// Tracks generated monthly invoices so the same period cannot be invoiced twice.
model PeriodeMaintenance {
  id        Int      @id @default(autoincrement())
  contratId Int      @map("contrat_id")
  annee     Int
  mois      Int
  factureId Int?     @unique @map("facture_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contrat ContratMaintenance @relation(fields: [contratId], references: [id], onDelete: Cascade)
  facture Facture?           @relation(fields: [factureId], references: [id])

  @@unique([contratId, annee, mois])
  @@index([contratId])
  @@map("periodes_maintenance")
}

// ─── Phase 4 — Revenus Malt ──────────────────────────────────────────────────

/// Revenue from Malt platform missions. Malt handles the invoicing (mandat);
/// only the net amount received is tracked here for URSSAF + seuils aggregation.
model RevenuMalt {
  id               Int      @id @default(autoincrement())
  dateEncaissement DateTime @map("date_encaissement") @db.Date
  montantNet       Decimal  @map("montant_net") @db.Decimal(12, 2)
  description      String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([dateEncaissement])
  @@map("revenus_malt")
}
