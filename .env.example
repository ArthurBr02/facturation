# ---------------------------------------------------------------------------
# Facturation — example environment file.
# Copy to `.env` and fill in the values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
POSTGRES_USER=facturation
POSTGRES_PASSWORD=change-me
POSTGRES_DB=facturation
POSTGRES_PORT=5432

# Connection string used by the API (Prisma). Inside docker-compose the host is
# `db`; when running the API on the host directly, use `localhost`.
DATABASE_URL=postgresql://facturation:change-me@db:5432/facturation?schema=public

# --- API ---
NODE_ENV=production
API_PORT=3000
# Secret used to sign authentication tokens (JWT). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime (e.g. 12h, 7d).
JWT_EXPIRES_IN=7d

# Single-user credentials. The API seeds this account on first start.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Web (frontend) ---
WEB_PORT=8080

# --- Google Drive (file storage) ---
# Auth method A — OAuth2 user credentials (preferred for personal Drive)
# Run: node back/scripts/get-drive-token.mjs to obtain the refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Auth method B — Service account (only works with Shared Drives / Google Workspace)
GOOGLE_APPLICATION_CREDENTIALS=/app/storage/google-credentials.json
# Drive folder id that acts as the root of the "Facturation/" tree.
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Set to "false" to disable Drive uploads in local/dev environments.
DRIVE_ENABLED=false

# --- E-mail alerts (SMTP / Nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Sender and recipient of system alerts (upload failures, backup status).
ALERT_FROM=facturation@example.com
ALERT_TO=admin@example.com
# Set to "false" to disable outgoing mail in local/dev environments.
MAIL_ENABLED=false

# --- Background jobs ---
# Cron expression for the upload-retry worker (default: every 5 minutes).
UPLOAD_RETRY_CRON=*/5 * * * *
# Max upload attempts before the queue item is marked as failed.
UPLOAD_MAX_ATTEMPTS=5
# Cron expression for the weekly DB backup (default: Sunday 02:00).
BACKUP_CRON=0 2 * * 0
